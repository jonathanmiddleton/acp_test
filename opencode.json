{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": ["copilot"],
  "permission": {
    "hello_world": {
      "*": "allow"
    }
  },
  "provider": {
    "copilot": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Copilot Bridge",
      "options": {
        "baseURL": "http://127.0.0.1:8765/v1",
        "apiKey": "not-required"
      },
      "models": {
        "gpt-4.1": {
          "name": "GPT-4.1",
          "tool_call": true,
          "limit": {
            "context": 131072,
            "output": 32768
          }
        },
        "gpt-4o": {
          "name": "GPT-4o",
          "tool_call": true,
          "limit": {
            "context": 131072,
            "output": 32768
          }
        },
        "auto": {
          "name": "Auto",
          "tool_call": true,
          "limit": {
            "context": 131072,
            "output": 32768
          }
        }
      }
    }
  },
  "model": "copilot/gpt-4.1"
}
