def eval_expr(expr: str) -> float:
    i, n = 0, len(expr)
    def skip():
        nonlocal i
        while i < n and expr[i] == ' ':
            i += 1
    def number():
        nonlocal i
        skip()
        start, dot = i, False
        while i < n and (expr[i].isdigit() or expr[i] == '.'):
            if expr[i] == '.':
                if dot: raise ValueError("Invalid number")
                dot = True
            i += 1
        if start == i: raise ValueError("Expected number")
        try: return float(expr[start:i])
        except: raise ValueError("Invalid number")
    def factor():
        nonlocal i
        skip()
        if i < n and expr[i] in '+-':
            sign = 1
            if expr[i] == '-': sign = -1
            i += 1
            return sign * factor()
        elif i < n and expr[i] == '(':
            i += 1
            skip()
            if i < n and expr[i] == ')':
                raise ValueError("Empty parentheses")
            val = expr_()
            skip()
            if i >= n or expr[i] != ')': raise ValueError("Mismatched parenthesis")
            i += 1
            return val
        elif i < n and (expr[i].isdigit() or expr[i] == '.'):
            return number()
        else:
            raise ValueError("Invalid factor")
    def term():
        val = factor()
        while True:
            skip()
            if i < n and expr[i] in '*/':
                op = expr[i]
                i += 1
                right = factor()
                if op == '*': val *= right
                else:
                    if right == 0: raise ValueError("Division by zero")
                    val /= right
            else: break
        return val
    def expr_():
        val = term()
        while True:
            skip()
            if i < n and expr[i] in '+-':
                op = expr[i]
                i += 1
                right = term()
                if op == '+': val += right
                else: val -= right
            else: break
        return val
    skip()
    if i == n:
        raise ValueError("Empty expression")
    val = expr_()
    skip()
    if i != n: raise ValueError("Invalid syntax")
    return val
