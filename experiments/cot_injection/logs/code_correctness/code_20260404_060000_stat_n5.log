def eval_expr(expr: str) -> float:
    def parse():
        nonlocal i
        def skip():
            while i < n and expr[i] == ' ':
                i += 1

        def number():
            skip()
            start = i
            dot = False
            while i < n and (expr[i].isdigit() or expr[i] == '.'):
                if expr[i] == '.':
                    if dot:
                        raise ValueError("Invalid number")
                    dot = True
                i += 1
            if start == i:
                raise ValueError("Expected number")
            return float(expr[start:i])

        def factor():
            skip()
            if i < n and expr[i] == '(':
                i += 1
                val = expr_()
                skip()
                if i >= n or expr[i] != ')':
                    raise ValueError("Mismatched parenthesis")
                i += 1
                return val
            elif i < n and (expr[i].isdigit() or expr[i] == '.'):
                return number()
            elif i < n and expr[i] in '+-':
                sign = 1
                if expr[i] == '-':
                    sign = -1
                i += 1
                return sign * factor()
            else:
                raise ValueError("Invalid factor")

        def term():
            val = factor()
            while True:
                skip()
                if i < n and expr[i] in '*/':
                    op = expr[i]
                    i += 1
                    right = factor()
                    if op == '*':
                        val *= right
                    else:
                        if right == 0:
                            raise ValueError("Division by zero")
                        val /= right
                else:
                    break
            return val

        def expr_():
            val = term()
            while True:
                skip()
                if i < n and expr[i] in '+-':
                    op = expr[i]
                    i += 1
                    right = term()
                    if op == '+':
                        val += right
                    else:
                        val -= right
                else:
                    break
            return val

        return expr_()

    expr = expr.strip()
    i = 0
    n = len(expr)
    val = parse()
    while i < n and expr[i] == ' ':
        i += 1
    if i != n:
        raise ValueError("Invalid syntax")
    return val
