def eval_expr(expr: str) -> float:
    expr = expr.strip()
    if not expr:
        raise ValueError("Empty expression")
    n = len(expr)
    i = 0

    def parse_expr():
        nonlocal i
        val = parse_term()
        while True:
            skip_spaces()
            if i < n and expr[i] in '+-':
                op = expr[i]
                i += 1
                right = parse_term()
                val = val + right if op == '+' else val - right
            else:
                break
        return val

    def parse_term():
        nonlocal i
        val = parse_factor()
        while True:
            skip_spaces()
            if i < n and expr[i] in '*/':
                op = expr[i]
                i += 1
                right = parse_factor()
                if op == '*':
                    val *= right
                else:
                    if right == 0:
                        raise ValueError("Division by zero")
                    val /= right
            else:
                break
        return val

    def parse_factor():
        nonlocal i
        skip_spaces()
        sign = 1
        while i < n and expr[i] in '+-':
            if expr[i] == '-':
                sign *= -1
            i += 1
            skip_spaces()
        if i < n and expr[i] == '(':
            i += 1
            val = parse_expr()
            skip_spaces()
            if i >= n or expr[i] != ')':
                raise ValueError("Mismatched parenthesis")
            i += 1
            return sign * val
        else:
            return sign * parse_number()

    def parse_number():
        nonlocal i
        skip_spaces()
        start = i
        dot = False
        while i < n and (expr[i].isdigit() or expr[i] == '.'):
            if expr[i] == '.':
                if dot:
                    raise ValueError("Invalid number format")
                dot = True
            i += 1
        if start == i:
            raise ValueError("Expected number")
        return float(expr[start:i])

    def skip_spaces():
        nonlocal i
        while i < n and expr[i] == ' ':
            i += 1

    val = parse_expr()
    skip_spaces()
    if i != n:
        raise ValueError("Invalid syntax")
    return val
