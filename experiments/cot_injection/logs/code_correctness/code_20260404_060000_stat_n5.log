            return val

        def expr_():
            val = term()
            while True:
                skip()
                if i < n and expr[i] in '+-':
                    op = expr[i]
                    i += 1
                    right = term()
                    if op == '+':
                        val += right
                    else:
                        val -= right
                else:
                    break
            return val

